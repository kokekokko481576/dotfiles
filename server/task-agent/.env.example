# ==================================================
# .env.example — task-agent / wani(ワニ博士アプリ) 共用の環境変数
# このファイルはgit管理対象。.env は .gitignore 済み。
#
# docker-compose経由の実行では、このファイルの内容がenv_fileとして注入される
# (task-agentの2サービスとwaniが共用。server/.envとは分離)。
#
# 注意: docker composeのenv_fileは行内コメント(値の後ろの # ...)を値の一部として
# 読んでしまうので、コメントは必ず独立した行に書くこと(過去に行内コメントで
# waniが起動ループになった実績あり)。
# ==================================================

# ---- GitHub ----
# Fine-grained PAT。対象: personal-tasksリポジトリ、権限: Projects(rw) / Issues(rw)
GITHUB_TOKEN=

# ProjectのオーナーのGitHubログイン名(個人Org配下ならOrg名)
GITHUB_PROJECT_OWNER=

# 個人アカウント直下のProjectなら user、Organization配下なら organization
GITHUB_PROJECT_OWNER_TYPE=user

# Project(V2)の番号(ProjectのURL末尾の数字)
GITHUB_PROJECT_NUMBER=

# ステータスを表すSingle selectフィールド名
GITHUB_STATUS_FIELD_NAME=Status

# ---- Discord ----
# docker-compose経由（本番運用）なら、../.env（server/.env）の
# DISCORD_TOKEN_OLLAMA / DISCORD_CHANNEL_OLLAMA がdocker-compose.ymlで
# 自動的にマッピングされるので、ここは空でよい。
# ローカルでpython src/job_recommend.py等を直接実行して動作確認する場合のみ、
# task-agent専用Bot（butler-botとは別。取得手順: guide/12）のトークン・チャンネルIDを
# ここに直接入れる。
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=

# ---- Ollama（自宅サーバー上のローカルLLM）----
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# ---- 生ログ・日次状態の保存先 ----
# docker-compose経由なら/mnt/data/ai/task-agent(またはwani)がマウントされる。
DATA_DIR=/app/data

# ---- 挙動調整 ----
# 対象issueを絞るラベル(カンマ区切り、空なら全ラベル対象)
TASK_LABELS=
TIMEZONE=Asia/Tokyo
