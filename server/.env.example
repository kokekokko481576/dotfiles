# ==================================================
# .env.example  —  実際の認証情報は .env に記入すること
# このファイルはgit管理対象。.env は .gitignore 済み。
# ==================================================

# ---- Immich ----
UPLOAD_LOCATION=/mnt/data/immich
IMMICH_VERSION=release
DB_PASSWORD=                  # 任意の強いパスワード（例: openssl rand -hex 32）
DB_USERNAME=immich
DB_DATABASE_NAME=immich

# ---- Google / Gemini ----
# https://aistudio.google.com/app/apikey で取得
GEMINI_API_KEY=

# ---- Discord ----
# butler-bot（Gemini）用。取得手順: guide/03_Discord_Bot作成.md を参照
DISCORD_TOKEN_BUTLER=
# task-agent（Ollama）用の別Bot。同じBot名でGemini/Ollamaが喋ると分かりにくいため分離。
# 取得手順: guide/12_タスク管理エージェント設定.md を参照
DISCORD_TOKEN_OLLAMA=
DISCORD_GUILD_ID=             # サーバーID（開発者モードで右クリックコピー）
DISCORD_CHANNEL_NOTIFY=       # #butler-notify チャンネルID
DISCORD_CHANNEL_CHAT=         # #butler-chat チャンネルID
DISCORD_CHANNEL_OLLAMA=       # #task_agent チャンネルID（task-agent用）
DISCORD_OWNER_ID=             # 自分のDiscordユーザーID（開発者モードで自分のアイコンを右クリック→IDをコピー）
                              # 設定するとエージェントモード（ホストのシェル/ファイル操作ツール）が有効になる。
                              # 未設定の間は常に無効（詳細: plan/11_agent-control.md）

# ---- Switchbot ----
# https://app.switch-bot.com/profile → 開発者オプション
SWITCHBOT_TOKEN=
SWITCHBOT_SECRET=

# ---- n8n ----
N8N_PASSWORD=                 # n8n管理画面のパスワード

# ---- Ollama（同一サーバー上でCPU推論。GPU PC完成後はそちらのURLに変更）----
OLLAMA_BASE_URL=http://ollama:11434

# ---- restic バックアップ（guide/10_バックアップ.md）----
RESTIC_REPOSITORY=/mnt/data/backup/restic-repo
RESTIC_PASSWORD=              # openssl rand -hex 32 等。失うとバックアップが復元不可能になるので別途保管すること

# ---- Samba（guide/07_Samba設定.md）----
SAMBA_PASSWORD=                # 変更したら `docker compose up -d samba` で再作成すれば反映される

# ---- LiteLLM（Vertex AI経由のGemini中継。GEMINI_API_KEYの請求が枯渇した場合の代替経路）----
# vertex-sa.json（サービスアカウント鍵、.gitignore済み）が必要
LITELLM_MASTER_KEY=             # openssl rand -hex 24 等。OpenWebUI/Butler Botがこのキーで中継にアクセスする

# ---- GitHub（ワニ博士アプリ/task-agent共用。guide/13）----
# 注意: docker composeのenv_fileは行内コメントを値として読むため、
# 実際の.envでは値の後ろにコメントを書かないこと
# Classic PAT(スコープ: repo, project)。個人アカウント直下のProject V2は
# fine-grained PAT非対応(GitHub側未実装)のためclassic必須
GITHUB_TOKEN=
# ProjectオーナーのGitHubログイン名
GITHUB_PROJECT_OWNER=
# 個人アカウント直下なら user、Organization配下なら organization
GITHUB_PROJECT_OWNER_TYPE=user
# Project(V2)のURL末尾の数字
GITHUB_PROJECT_NUMBER=
GITHUB_STATUS_FIELD_NAME=Status
