# ==================================================
# .env.example  —  実際の認証情報は .env に記入すること
# このファイルはgit管理対象。.env は .gitignore 済み。
# ==================================================

# ---- Immich ----
UPLOAD_LOCATION=/mnt/data/immich
IMMICH_VERSION=release

# ---- Navidrome（音楽ストリーミング。guide/15_音楽サーバー設定.md）----
# 音源フォルダ。Sambaの/mnt/data配下に置くとsmb://kokko-server-pavilion/data/music から
# 直接コピーできる。Navidromeはこのフォルダを読み取り専用でスキャンする(ファイルは書き換えない)。
# 認証情報は無し。ログイン用の管理者アカウントは初回ブラウザアクセス時に画面上で作成する。
MUSIC_LOCATION=/mnt/data/music
DB_PASSWORD=                  # 任意の強いパスワード（例: openssl rand -hex 32）
DB_USERNAME=immich
DB_DATABASE_NAME=immich

# ---- Google / Gemini ----
# https://aistudio.google.com/app/apikey で取得
GEMINI_API_KEY=

# ---- Discord ----
# butler-bot（Gemini）用。取得手順: guide/03_Discord_Bot作成.md を参照
DISCORD_TOKEN_BUTLER=
# task-agent（Ollama）用の別Bot。同じBot名でGemini/Ollamaが喋ると分かりにくいため分離。
# 取得手順: guide/12_タスク管理エージェント設定.md を参照
DISCORD_TOKEN_OLLAMA=
DISCORD_GUILD_ID=             # サーバーID（開発者モードで右クリックコピー）
DISCORD_CHANNEL_NOTIFY=       # #butler-notify チャンネルID
DISCORD_CHANNEL_CHAT=         # #butler-chat チャンネルID
DISCORD_CHANNEL_OLLAMA=       # #task_agent チャンネルID（task-agent用）
DISCORD_OWNER_ID=             # 自分のDiscordユーザーID（開発者モードで自分のアイコンを右クリック→IDをコピー）
                              # 設定するとエージェントモード（ホストのシェル/ファイル操作ツール）が有効になる。
                              # 未設定の間は常に無効（詳細: plan/11_agent-control.md）

# ---- Switchbot ----
# https://app.switch-bot.com/profile → 開発者オプション
SWITCHBOT_TOKEN=
SWITCHBOT_SECRET=

# ---- n8n ----
N8N_PASSWORD=                 # n8n管理画面のパスワード

# ---- Ollama（同一サーバー上でCPU推論。GPU PC完成後はそちらのURLに変更）----
OLLAMA_BASE_URL=http://ollama:11434

# ---- restic バックアップ（guide/10_バックアップ.md）----
RESTIC_REPOSITORY=/mnt/data/backup/restic-repo
RESTIC_PASSWORD=              # openssl rand -hex 32 等。失うとバックアップが復元不可能になるので別途保管すること

# ---- Samba（guide/07_Samba設定.md）----
SAMBA_PASSWORD=                # 変更したら `docker compose up -d samba` で再作成すれば反映される

# ---- LiteLLM（Vertex AI経由のGemini中継。GEMINI_API_KEYの請求が枯渇した場合の代替経路）----
# vertex-sa.json（サービスアカウント鍵、.gitignore済み）が必要
LITELLM_MASTER_KEY=             # openssl rand -hex 24 等。OpenWebUI/Butler Botがこのキーで中継にアクセスする

# ---- DeepSeek（執事Discord bot / CLIツール scripts/ask.py 用）----
# 空でもよい。空のうちはlitellmが deepseek-* 呼び出しをGeminiに自動フォールバックする。
# キーを入れて BUTLER_LLM_MODEL=deepseek-chat にすると執事botがDeepSeekに切り替わる。
# 取得: https://platform.deepseek.com/ の API keys
DEEPSEEK_API_KEY=
# 執事botの会話モデル。既定 gemini-2.5-flash-vertex。DeepSeek導入時は deepseek-chat に。
BUTLER_LLM_MODEL=
# 執事botがLLMに毎回送る会話履歴の上限メッセージ数(既定16)。増やすと文脈は増えるがトークン増
HISTORY_MAX_MESSAGES=

# ---- CouchDB（Obsidian LiveSync。guide/16。--profile obsidian で起動）----
COUCHDB_USER=obsidian
COUCHDB_PASSWORD=            # ★必ず強いパスワードに。空だと既定値になり危険

# ---- GitHub（ワニ博士アプリ/task-agent共用。guide/13）----
# 注意: docker composeのenv_fileは行内コメントを値として読むため、
# 実際の.envでは値の後ろにコメントを書かないこと
# Classic PAT(スコープ: repo, project)。個人アカウント直下のProject V2は
# fine-grained PAT非対応(GitHub側未実装)のためclassic必須
GITHUB_TOKEN=
# ProjectオーナーのGitHubログイン名
GITHUB_PROJECT_OWNER=
# 個人アカウント直下なら user、Organization配下なら organization
GITHUB_PROJECT_OWNER_TYPE=user
# Project(V2)のURL末尾の数字
GITHUB_PROJECT_NUMBER=
GITHUB_STATUS_FIELD_NAME=Status

# ---- Vaultwarden（パスワード管理。guide/18_vaultwarden設定.md）----
# 管理画面(/admin)のパスワード。openssl rand -base64 48 等で生成
VAULTWARDEN_ADMIN_TOKEN=
# 自分のアカウントを作成したら false にすること(既定はtrue=初回サインアップ用に開放)
VAULTWARDEN_SIGNUPS_ALLOWED=true

# ---- Miniflux（RSSリーダー。guide/19_miniflux設定.md）----
MINIFLUX_DB_PASSWORD=          # 任意の強いパスワード
MINIFLUX_ADMIN_USERNAME=kokko
MINIFLUX_ADMIN_PASSWORD=       # 任意の強いパスワード（ログイン後に画面から変更可）

# ---- Karakeep（AIブックマーク。guide/20_karakeep設定.md）----
KARAKEEP_MEILI_MASTER_KEY=     # openssl rand -base64 36 | tr -dc 'A-Za-z0-9' 等
KARAKEEP_NEXTAUTH_SECRET=      # openssl rand -base64 36 等

# ---- Paperless-ngx（書類管理+OCR。guide/21_paperless設定.md）----
PAPERLESS_DB_PASSWORD=         # 任意の強いパスワード
PAPERLESS_SECRET_KEY=          # python3 -c "import secrets; print(secrets.token_urlsafe(64))" 等
PAPERLESS_ADMIN_USER=kokko
PAPERLESS_ADMIN_PASSWORD=      # 任意の強いパスワード（ログイン後に画面から変更可）
